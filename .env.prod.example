# Copy this file to .env before production deployment and replace all values.

DB_NAME=app_db
DB_USER=app_user_prod
DB_PASSWORD=ReplaceWithLongRandomPassword_AtLeast24Chars
DB_ROOT_PASSWORD=ReplaceWithAnotherLongRandomPassword_AtLeast24Chars

APP_SECRET=ReplaceWithSymfonyAppSecret_AtLeast32Chars
JWT_PASSPHRASE=ReplaceWithJwtPassphrase_AtLeast32Chars

# Allowed frontend origin regex used by Nelmio CORS
CORS_ALLOW_ORIGIN=^https://(sae401\.mmi24b07\.mmi-troyes\.fr)$

# Public API origin used by the Vue app in production
VITE_API_ORIGIN=https://sae401.mmi24b07.mmi-troyes.fr
