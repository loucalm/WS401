{% extends 'base.html.twig' %}

{% block title %}{{ 'login.title'|trans({}, 'admin') }}{% endblock %}

{% block body %}
    <style>
        body {
            margin: 0;
            min-height: 100vh;
            font-family: "Segoe UI", sans-serif;
            background:
                radial-gradient(circle at top left, rgba(31, 111, 120, 0.34), transparent 28%),
                radial-gradient(circle at bottom right, rgba(17, 45, 78, 0.28), transparent 30%),
                linear-gradient(135deg, #f5f7fa 0%, #dfe7ef 100%);
            color: #102a43;
        }

        .login-shell {
            min-height: 100vh;
            display: grid;
            place-items: center;
            padding: 1.5rem;
        }

        .login-card {
            width: min(100%, 980px);
            display: grid;
            grid-template-columns: minmax(280px, 1.05fr) minmax(320px, 0.95fr);
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border-radius: 32px;
            overflow: hidden;
            box-shadow: 0 30px 80px rgba(16, 42, 67, 0.16);
        }

        .login-aside {
            padding: 2.5rem;
            background: linear-gradient(160deg, #112d4e 0%, #1f6f78 100%);
            color: #f8fbff;
            display: grid;
            gap: 1.25rem;
            align-content: space-between;
        }

        .login-aside h1 {
            margin: 0;
            font-size: clamp(2rem, 4vw, 3.25rem);
            line-height: 0.95;
            letter-spacing: -0.05em;
        }

        .login-aside p {
            margin: 0;
            color: rgba(248, 251, 255, 0.82);
            max-width: 34ch;
        }

        .login-locale {
            display: inline-flex;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

        .login-locale a {
            color: #fff;
            text-decoration: none;
            padding: 0.65rem 0.9rem;
            border-radius: 999px;
            border: 1px solid rgba(255, 255, 255, 0.22);
            background: rgba(255, 255, 255, 0.1);
        }

        .login-form-panel {
            padding: 2.5rem;
            display: grid;
            align-content: center;
        }

        .login-form-panel h2 {
            margin: 0 0 0.5rem;
            font-size: 1.8rem;
        }

        .login-form-panel p {
            margin: 0 0 1.5rem;
            color: #52606d;
        }

        .login-alert {
            margin-bottom: 1rem;
            padding: 0.9rem 1rem;
            border-radius: 14px;
            background: #fff1f0;
            color: #b42318;
            border: 1px solid #fecdca;
        }

        .login-group {
            display: grid;
            gap: 0.45rem;
            margin-bottom: 1rem;
        }

        .login-group label {
            font-weight: 600;
        }

        .login-group input {
            border: 1px solid #d9e2ec;
            border-radius: 14px;
            padding: 0.95rem 1rem;
            font-size: 1rem;
            background: #fff;
        }

        .login-submit {
            width: 100%;
            border: none;
            border-radius: 16px;
            padding: 1rem 1.1rem;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            color: #fff;
            background: linear-gradient(135deg, #112d4e 0%, #1f6f78 100%);
        }

        @media (max-width: 860px) {
            .login-card {
                grid-template-columns: 1fr;
            }
        }
    </style>

    <main class="login-shell">
        <section class="login-card">
            <aside class="login-aside">
                <div>
                    <h1>{{ 'login.heading'|trans({}, 'admin') }}</h1>
                    <p>{{ 'login.intro'|trans({}, 'admin') }}</p>
                </div>

                <nav class="login-locale" aria-label="{{ 'menu.international'|trans({}, 'admin') }}">
                    <a href="{{ path('admin_locale', { locale: 'fr' }) }}">{{ 'menu.french'|trans({}, 'admin') }}</a>
                    <a href="{{ path('admin_locale', { locale: 'en' }) }}">{{ 'menu.english'|trans({}, 'admin') }}</a>
                </nav>
            </aside>

            <div class="login-form-panel">
                <h2>{{ 'login.title'|trans({}, 'admin') }}</h2>
                <p>{{ 'login.intro'|trans({}, 'admin') }}</p>

                {% if error %}
                    <div class="login-alert">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                {% endif %}

                {% if access_denied %}
                    <div class="login-alert">{{ 'login.denied'|trans({}, 'admin') }}</div>
                {% endif %}

                <form method="post">
                    <div class="login-group">
                        <label for="username">{{ 'fields.email'|trans({}, 'admin') }}</label>
                        <input type="email" id="username" name="_username" value="{{ last_username }}" required autofocus autocomplete="email">
                    </div>

                    <div class="login-group">
                        <label for="password">{{ 'login.password'|trans({}, 'admin') }}</label>
                        <input type="password" id="password" name="_password" required autocomplete="current-password">
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <button class="login-submit" type="submit">{{ 'login.submit'|trans({}, 'admin') }}</button>
                </form>
            </div>
        </section>
    </main>
{% endblock %}